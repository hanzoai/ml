uint byte_u(uint base, uint b) {
    return (w[base + (b >> 2u)] >> ((b & 3u) * 8u)) & 0xFFu;
}

void main() {
    uint n = gl_GlobalInvocationID.x;
    if (n >= nout) {
        return;
    }
    uint nblocks = k / 256u;
    uint rowbase = n * nblocks * BLK_U32;
    float acc = 0.0;
    for (uint blk = 0u; blk < nblocks; blk++) {
        uint base = rowbase + blk * BLK_U32;
        float d = float(unpackHalf2x16(w[base]).x);
        uint xblk = blk * 256u;
        for (uint e = 0u; e < 8u; e++) {
            uint sc = byte_u(base, 74u + e);    // scales[e]
            uint qh_e = byte_u(base, 66u + e);  // qh[e]
            for (uint l = 0u; l < 4u; l++) {
                uint nib = (l < 2u) ? (sc & 0xFu) : (sc >> 4u);
                float db = d * (0.5 + float(nib)) * 0.25;
                uint idx = byte_u(base, 2u + 4u * e + l)
                         | ((qh_e << (8u - 2u * l)) & 0x300u);
                uint glo = IQ2S_GRID[2u * idx];
                uint ghi = IQ2S_GRID[2u * idx + 1u];
                uint signs = byte_u(base, 34u + 4u * e + l);  // qs[32 + 4e + l]
                uint xoff = xblk + e * 32u + l * 8u;
                for (uint j = 0u; j < 8u; j++) {
                    uint g = (j < 4u) ? ((glo >> (8u * j)) & 0xFFu)
                                      : ((ghi >> (8u * (j - 4u))) & 0xFFu);
                    float sign = ((signs >> j) & 1u) != 0u ? -1.0 : 1.0;
                    acc += db * float(g) * sign * x[xoff + j];
                }
            }
        }
    }
    y[n] = acc;
}
